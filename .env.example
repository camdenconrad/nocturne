# Copy to .env (gitignored) and paste your own client id.
#
# Get one at https://developer.spotify.com/dashboard:
#   Create app → Redirect URI MUST be exactly http://127.0.0.1:8898/login
#   (127.0.0.1, not localhost — Spotify rejects localhost on new apps)
#   → tick "Web API" → Save → Settings → Client ID
#
# No client secret: librespot's OAuth flow is PKCE.
NOCTURNE_CLIENT_ID=
